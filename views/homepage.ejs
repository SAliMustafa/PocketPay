<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/cards.css">
    <link rel="stylesheet" href="/css/home.css">
    <title>Homepage</title>
</head>
<body>
    <%- include('./partials/navbar') %>
    <main>
        <h1>Welcome back, <%= user.username %></h1>
        <section class="box">
            <h2>Total Balance</h2>
            <p class="balance">BD <%=totalBalance.toFixed(2)%> </p>
        </section>
        <section>
            <div class="section-header">
                <h2>Your Cards</h2>
                <a href="/card">View all</a>
            </div>
            <ul class="card-grid">
                <% for (let oneCard of card){%>
                    <li>
                        <a href="/card/<%=oneCard._id%>" class="card-visual card-<%=oneCard.cardType%>">
                            <p class="card-type"><%=oneCard.cardType%></p>
                            <p class="card-nickname"><%=oneCard.nickname%></p>
                            <p class="card-number">xxxx xxxx xxxx <%=oneCard.cardNumber%></p>
                            <p class="card-balance">BD <%=oneCard.balance.toFixed(2)%></p>
                        </a>
                    </li>
                <%}%>
                <li>
                    <a href="/card/new" class="card-tile-add">+ Add Card</a>
                </li>
            </ul>

        </section>
        <section>
            <h2>Recent Activity</h2>
            <% if (transactions.length === 0){%>
                <p>No transactions yet</p>
            <%}else{%>
            <ul class="transaction-list box">
              <% for (let t of transactions){%>
                <li class="transaction-row">
                  <div>
                    <p><%= t.transactionType %></p>
                    <p><%= t.createdAt.toDateString() %></p>
                    <% if (t.transactionType==='transfer_in' ) { %>
                      <p>from: <%= t.counterparty.username %></p>
                      <% } else if (t.transactionType==='transfer_out' ) { %>
                        <p>to: <%= t.counterparty.username %></p>
                      <% } %>
                  </div>
                  <%if(t.transactionType=='deposit' || t.transactionType=='transfer_in' ){%>
                    <p class="amount-positive">+BD <%=t.amount.toFixed(2)%></p>
                    <%}else if(t.transactionType=='transfer_out' || t.transactionType=='withdrawal' ){%>
                      <p class="amount-negative">-BD <%=t.amount.toFixed(2)%></p>
                      <%}%>
                    </li>
                  <%}%>
            </ul>
            <% }%>
        </section>
    </main>
</body>
</html>